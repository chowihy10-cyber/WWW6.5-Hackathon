# ============================================
# PlantDAO 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# Sepolia 测试网 RPC URL
# 推荐使用 Alchemy (https://www.alchemy.com/) 或 Infura (https://www.infura.io/)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v3/YOUR_API_KEY

# 部署者钱包私钥 (不要带 0x 前缀)
PRIVATE_KEY=YOUR_PRIVATE_KEY